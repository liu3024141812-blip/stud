<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="390.0" prefWidth="700.0" styleClass="form-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.ScoreInsertController">
   <children>
      <VBox spacing="20.0" styleClass="form-card">
         <children>
            <Label styleClass="form-title" text="新增成绩" />
            <GridPane hgap="18.0" vgap="14.0">
               <children>
                  <Label styleClass="field-label" text="学生" />
                  <ComboBox fx:id="studentId" prefWidth="480.0" GridPane.columnIndex="1" />
                  <Label styleClass="field-label" text="课程" GridPane.rowIndex="1" />
                  <ComboBox fx:id="courseId" prefWidth="480.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label styleClass="field-label" text="考试成绩" GridPane.rowIndex="2" />
                  <TextField fx:id="score" promptText="请输入分数" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancel" styleClass="secondary-button" text="取消" />
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#save" styleClass="primary-button" text="保存" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
