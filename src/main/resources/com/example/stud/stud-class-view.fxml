<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudClassController">
    <children>
        <Button fx:id="searchbutton" layoutX="86.0" layoutY="37.0" mnemonicParsing="false" onAction="#search" text="搜索" />
        <TableView fx:id="results" layoutX="87.0" layoutY="74.0" prefHeight="239.0" prefWidth="381.0">
            <columns>
                <TableColumn fx:id="cid" prefWidth="75.0" text="Id" />
                <TableColumn fx:id="grade" prefWidth="75.0" text="年级" />
                <TableColumn fx:id="myclass" prefWidth="75.0" text="班级名称" />
                <TableColumn fx:id="mymajor" prefWidth="75.0" text="专业" />
            </columns>
        </TableView>
        <Button fx:id="insertbutton" layoutX="137.0" layoutY="37.0" mnemonicParsing="false" onAction="#insert" text="新增" />
        <Button fx:id="deletebutton" layoutX="427.0" layoutY="37.0" mnemonicParsing="false" onAction="#delete" text="删除" />
        <Button fx:id="updatebutton" layoutX="251.0" layoutY="37.0" mnemonicParsing="false" onAction="#update" text="修改" />
    </children>
</AnchorPane>
