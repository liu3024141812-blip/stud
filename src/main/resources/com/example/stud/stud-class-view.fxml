<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="394.0" prefWidth="604.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudClassController">
   <children>
      <TableView fx:id="results" layoutX="60.0" layoutY="45.0" prefHeight="269.0" prefWidth="484.0">
        <columns>
          <TableColumn fx:id="cid" prefWidth="75.0" text="id" />
            <TableColumn fx:id="mymajor" prefWidth="75.0" text="专业" />
          <TableColumn fx:id="grade" prefWidth="75.0" text="年级" />
            <TableColumn fx:id="myclass" prefWidth="75.0" text="班级" />
        </columns>
      </TableView>
      <Button fx:id="searchbutton" layoutX="60.0" layoutY="14.0" mnemonicParsing="false" onAction="#search" text="搜索" />
      <Button fx:id="insertbutton" layoutX="141.0" layoutY="14.0" mnemonicParsing="false" onAction="#insert" text="新增" />
      <Button fx:id="deletebutton" layoutX="504.0" layoutY="14.0" mnemonicParsing="false" onAction="#delete" text="删除" />
      <Button fx:id="updatebutton" layoutX="213.0" layoutY="14.0" mnemonicParsing="false" onAction="#update" text="修改" />
   </children>
</AnchorPane>
