<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="430.0" prefWidth="620.0" styleClass="form-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudClassUpdateController">
   <children>
      <VBox spacing="20.0" styleClass="form-card">
         <children>
            <Label styleClass="form-title" text="更新班级" />
            <GridPane hgap="18.0" vgap="14.0">
               <children>
                  <Label styleClass="field-label" text="ID" />
                  <Label fx:id="cid" text="0" GridPane.columnIndex="1" />
                  <Label styleClass="field-label" text="年级" GridPane.rowIndex="1" />
                  <TextField fx:id="grade" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label styleClass="field-label" text="专业" GridPane.rowIndex="2" />
                  <TextField fx:id="mymajor" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label styleClass="field-label" text="班级编号" GridPane.rowIndex="3" />
                  <TextField fx:id="myclass" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="cancelbutton" mnemonicParsing="false" onAction="#cancel" styleClass="secondary-button" text="取消" />
                  <Button fx:id="updatebutton" mnemonicParsing="false" onAction="#update" styleClass="primary-button" text="更新" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
