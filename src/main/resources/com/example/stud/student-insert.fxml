<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="430.0" prefWidth="620.0" styleClass="form-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudentInsertController">
   <children>
      <VBox spacing="20.0" styleClass="form-card">
         <children>
            <Label styleClass="form-title" text="新增学生" />
            <GridPane hgap="18.0" vgap="14.0">
               <children>
                  <Label styleClass="field-label" text="姓名" />
                  <TextField fx:id="name" promptText="请输入姓名" GridPane.columnIndex="1" />
                  <Label styleClass="field-label" text="学号" GridPane.rowIndex="1" />
                  <TextField fx:id="studentNo" promptText="请输入学号" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label styleClass="field-label" text="班级" GridPane.rowIndex="2" />
                  <ComboBox fx:id="classId" prefWidth="380.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label styleClass="field-label" text="已修学分" GridPane.rowIndex="3" />
                  <TextField fx:id="credits" promptText="请输入学分" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancel" styleClass="secondary-button" text="取消" />
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#save" styleClass="primary-button" text="保存" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
