<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudentController">
   <children>
      <TableView fx:id="results" layoutX="36.0" layoutY="59.0" prefHeight="322.0" prefWidth="379.0">
        <columns>
          <TableColumn fx:id="id" prefWidth="75.0" text="id" />
          <TableColumn fx:id="name" prefWidth="75.0" text="姓名" />
            <TableColumn fx:id="student_no" prefWidth="75.0" text="学号" />
            <TableColumn fx:id="class_id" prefWidth="75.0" text="班级编号" />
            <TableColumn fx:id="credits" prefWidth="75.0" text="以修学分" />
        </columns>
      </TableView>
      <Button fx:id="searchButton" layoutX="47.0" layoutY="36.0" mnemonicParsing="false" onAction="#search" text="搜索" />
      <Button fx:id="insertButton" layoutX="116.0" layoutY="36.0" mnemonicParsing="false" onAction="#insert" text="新增" />
      <Button fx:id="updateButton" layoutX="186.0" layoutY="36.0" mnemonicParsing="false" onAction="#update" text="修改" />
      <Button fx:id="deleteButton" layoutX="375.0" layoutY="36.0" mnemonicParsing="false" onAction="#delete" text="删除" />
   </children>
</AnchorPane>
