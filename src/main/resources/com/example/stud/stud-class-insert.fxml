<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="390.0" prefWidth="620.0" styleClass="form-root" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.StudClassInsertController">
   <children>
      <VBox spacing="20.0" styleClass="form-card">
         <children>
            <Label styleClass="form-title" text="新增班级" />
            <GridPane hgap="18.0" vgap="14.0">
               <children>
                  <Label styleClass="field-label" text="年级" />
                  <TextField fx:id="grade" promptText="例如：2026" GridPane.columnIndex="1" />
                  <Label styleClass="field-label" text="专业" GridPane.rowIndex="1" />
                  <TextField fx:id="mymajor" promptText="请输入专业" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label styleClass="field-label" text="班级编号" GridPane.rowIndex="2" />
                  <TextField fx:id="myclass" promptText="请输入班级编号" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancel" styleClass="secondary-button" text="取消" />
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#save" styleClass="primary-button" text="保存" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
