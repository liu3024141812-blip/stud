<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.CourseController">
   <children>
      <Button fx:id="searchButton" layoutX="47.0" layoutY="27.0" mnemonicParsing="false" onAction="#search" text="搜索" />
      <Button fx:id="insertButton" layoutX="116.0" layoutY="27.0" mnemonicParsing="false" onAction="#insert" text="新增" />
      <Button fx:id="updateButton" layoutX="186.0" layoutY="27.0" mnemonicParsing="false" onAction="#update" text="修改" />
      <Button fx:id="deleteButton" layoutX="590.0" layoutY="27.0" mnemonicParsing="false" onAction="#delete" text="删除" />
      <TableView fx:id="results" layoutX="47.0" layoutY="72.0" prefHeight="322.0" prefWidth="600.0">
        <columns>
          <TableColumn fx:id="cid" prefWidth="50.0" text="ID" />
          <TableColumn fx:id="cimage" prefWidth="90.0" text="封面" />
          <TableColumn fx:id="cname" prefWidth="150.0" text="课程名称" />
          <TableColumn fx:id="teacher" prefWidth="120.0" text="教师名称" />
          <TableColumn fx:id="credits" prefWidth="75.0" text="学分" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
