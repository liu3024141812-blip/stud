<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="dashboard-page" stylesheets="@app.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.stud.controller.CourseController">
   <children>
      <VBox spacing="16.0" styleClass="card" VBox.vgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="18.0">
               <children>
                  <VBox minWidth="220.0">
                     <children>
                        <Label styleClass="section-title" text="课程管理" />
                        <Label styleClass="section-note" text="维护课程名称、教师、封面和学分" />
                     </children>
                  </VBox>
                  <HBox styleClass="toolbar" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField fx:id="keywordField" maxWidth="260.0" minWidth="150.0" onAction="#search" prefWidth="230.0" promptText="搜索课程或教师" styleClass="table-search-field" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#search" styleClass="secondary-button" text="搜索" />
                     </children>
                  </HBox>
                  <Region minWidth="8.0" HBox.hgrow="ALWAYS" />
                  <HBox styleClass="toolbar">
                     <children>
                        <Button fx:id="searchButton" mnemonicParsing="false" onAction="#query" styleClass="secondary-button" text="刷新" />
                        <Button fx:id="insertButton" mnemonicParsing="false" onAction="#insert" styleClass="primary-button" text="新增" />
                        <Button fx:id="updateButton" mnemonicParsing="false" onAction="#update" styleClass="secondary-button" text="修改" />
                        <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#delete" styleClass="danger-button" text="删除" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <TableView fx:id="results" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="cid" prefWidth="80.0" text="ID" />
                  <TableColumn fx:id="cimage" prefWidth="140.0" text="封面" />
                  <TableColumn fx:id="cname" prefWidth="210.0" text="课程名称" />
                  <TableColumn fx:id="teacher" prefWidth="180.0" text="教师名称" />
                  <TableColumn fx:id="credits" prefWidth="110.0" text="学分" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
